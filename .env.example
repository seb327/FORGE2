PORT=3000
# Optional. Leave blank on Railway unless you want to force a custom public origin.
# Railway's RAILWAY_PUBLIC_DOMAIN is detected automatically for generated links.
APP_URL=
# Optional. Generated playables/decks use this path. If omitted, Forge uses
# RAILWAY_VOLUME_MOUNT_PATH/forge-generated when a Railway volume is attached.
GENERATED_ASSETS_DIR=
SECRET_KEY=replace_with_a_long_random_secret

# Anthropic
ANTHROPIC_API_KEY=
FORGE_MODEL=claude-sonnet-4-6
FORGE_PRO_MODEL=claude-fable-5
# Legacy GENESIS_MODEL / GENESIS_PRO_MODEL still work as fallbacks
# if you are migrating Railway variables from MOTOR GENESIS.

# Stripe, only if using paid checkout
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=

# VIP access codes, comma separated
VIP_CODES=FORGE-EARLY-ACCESS,VYBSTAK-PRO,VALENCIA-GAMECITY

# ── FORGE PLAYABLE (AI-generated prototype games) ──
# Model used to generate playables. Defaults to Claude Fable 5.
FORGE_PLAYABLE_MODEL=claude-fable-5
